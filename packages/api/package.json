{
  "name": "@enzo/api",
  "version": "0.1.0",
  "description": "REST API for Enzo assistant",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm -F @enzo/core build && pnpm -F @enzo/bootstrap build && tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@enzo/bootstrap": "workspace:*",
    "@enzo/core": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
