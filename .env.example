# Modelos
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=qwen2.5:7b

# Providers opcionales (para agentes complejos)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_API_KEY=

# API
PORT=3001

# Base de datos
DB_PATH=./enzo.db

# Workspace
ENZO_WORKSPACE_PATH=./workspace

# Skills
ENZO_SKILLS_PATH=~/.enzo/skills

# Timezone del servidor (IANA, e.g. America/New_York, Europe/Madrid, Asia/Tokyo)
# Required — no default is hardcoded. Falls back to system timezone if not set.
TZ=America/New_York

# Language code for the default user (BCP-47 primary tag, e.g. en, es, pt, fr)
# Falls back to system locale when not set.
DEFAULT_USER_LANGUAGE=en

# MCP (Model Context Protocol)
MCP_AUTO_CONNECT=true

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Search API
TAVILY_API_KEY=your_tavily_api_key_here
